---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllDocEntries } from '../lib/docs';

export async function getStaticPaths() {
  const allEntries = await getAllDocEntries();
  return allEntries.map((item) => ({
    params: { slug: item.slug },
    props: { item, allEntries }
  }));
}

const { item, allEntries } = Astro.props;
const { Content } = await render(item.entry);
const sectionEntries = allEntries
  .filter((entry) => entry.section === item.section)
  .sort((a, b) => a.order - b.order || a.title.localeCompare(b.title, 'ja'));
const currentIndex = sectionEntries.findIndex((entry) => entry.slug === item.slug);
const previous = currentIndex > 0 ? sectionEntries[currentIndex - 1] : undefined;
const next = currentIndex >= 0 && currentIndex < sectionEntries.length - 1 ? sectionEntries[currentIndex + 1] : undefined;
---

<BaseLayout title={`${item.title} | School Curriculum`}>
  <main class="docs-layout">
    <aside class="docs-sidebar">
      <h2>{item.section}</h2>
      <nav aria-label="Course navigation">
        {sectionEntries.map((entry) => (
          <a href={`/${entry.slug}/`} aria-current={entry.slug === item.slug ? 'page' : undefined}>{entry.title}</a>
        ))}
      </nav>
    </aside>

    <article class="doc-shell">
      <div class="breadcrumb">
        <a href="/">ホーム</a> / {item.section} / {item.title}
      </div>
      <div class="prose">
        <Content />
      </div>
      <nav class="pager" aria-label="Page navigation">
        {previous ? <a href={`/${previous.slug}/`}>前へ: {previous.title}</a> : <span></span>}
        {next ? <a href={`/${next.slug}/`}>次へ: {next.title}</a> : <span></span>}
      </nav>
    </article>
  </main>
</BaseLayout>
